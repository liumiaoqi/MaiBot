{
  "plugin_id": "a_memorix",
  "plugin_info": {
    "name": "A_Memorix",
    "version": "2.0.0",
    "description": "长期记忆与认知增强子系统，支持常用配置可视化与原始 TOML 兜底编辑。",
    "author": "A_Dawn"
  },
  "_note": "未在本 Schema 展示的高级键仍然有效，请通过源码模式或原始 TOML 编辑。",
  "layout": {
    "type": "tabs",
    "tabs": [
      {
        "id": "basic",
        "title": "基础",
        "sections": [
          "plugin",
          "embedding"
        ],
        "order": 1
      },
      {
        "id": "stability",
        "title": "稳定性",
        "sections": [
          "embedding.fallback",
          "embedding.paragraph_vector_backfill"
        ],
        "order": 2
      },
      {
        "id": "retrieval",
        "title": "检索",
        "sections": [
          "retrieval",
          "retrieval.search.smart_fallback",
          "retrieval.relation_vectorization",
          "retrieval.vector_pools",
          "retrieval.sparse",
          "threshold",
          "filter",
          "filter.retrieval.chat_stream",
          "filter.retrieval.chat_summary",
          "filter.retrieval.episode"
        ],
        "order": 3
      },
      {
        "id": "memory",
        "title": "记忆",
        "sections": [
          "episode",
          "person_profile",
          "memory"
        ],
        "order": 4
      },
      {
        "id": "operations",
        "title": "运维",
        "sections": [
          "advanced",
          "web.import",
          "web.import.timeout",
          "web.tuning"
        ],
        "order": 5
      }
    ]
  },
  "sections": {
    "plugin": {
      "name": "plugin",
      "title": "子系统状态",
      "description": "控制 A_Memorix 是否在宿主中启用。",
      "icon": null,
      "collapsed": false,
      "order": 1,
      "fields": {
        "enabled": {
          "name": "enabled",
          "type": "boolean",
          "default": false,
          "description": "是否启用 A_Memorix",
          "label": "启用 A_Memorix",
          "ui_type": "switch",
          "required": false,
          "hidden": false,
          "disabled": false,
          "order": 1,
          "hint": "默认关闭以简化首次配置；开启前请先配置可用的 embedding 模型。关闭后 A_Memorix 不会参与长期记忆写入、检索与运维。",
          "choices": null
        }
      }
    },
    "embedding": {
      "name": "embedding",
      "title": "Embedding",
      "description": "控制向量写入与检索的核心嵌入配置。",
      "icon": null,
      "collapsed": false,
      "order": 3,
      "fields": {
        "model_name": {
          "name": "model_name",
          "type": "string",
          "default": "auto",
          "description": "Embedding 模型选择",
          "label": "模型选择",
          "ui_type": "text",
          "required": false,
          "hidden": false,
          "disabled": false,
          "order": 1,
          "hint": "默认 auto，会按宿主环境自动选择可用 embedding 模型。",
          "placeholder": "auto",
          "choices": null
        },
        "dimension_request_mode": {
          "name": "dimension_request_mode",
          "type": "string",
          "default": "explicit",
          "description": "是否在请求中携带向量维度参数",
          "label": "维度请求模式",
          "ui_type": "select",
          "required": false,
          "hidden": false,
          "disabled": false,
          "order": 3,
          "hint": "explicit 仅在显式指定 dimensions 时传递；always 总是传递；never 始终不传。",
          "choices": [
            "explicit",
            "always",
            "never"
          ],
          "advanced": true
        },
        "batch_size": {
          "name": "batch_size",
          "type": "integer",
          "default": 32,
          "description": "单批请求大小",
          "label": "批大小",
          "ui_type": "number",
          "required": false,
          "hidden": false,
          "disabled": false,
          "order": 4,
          "hint": "批量过大可能放大模型或网络波动。",
          "min": 1,
          "max": 1024,
          "step": 1,
          "choices": null
        },
        "max_concurrent": {
          "name": "max_concurrent",
          "type": "integer",
          "default": 5,
          "description": "最大并发数",
          "label": "最大并发",
          "ui_type": "number",
          "required": false,
          "hidden": false,
          "disabled": false,
          "order": 5,
          "hint": "用于限制并行 embedding 请求数量。",
          "min": 1,
          "max": 128,
          "step": 1,
          "choices": null
        },
        "enable_cache": {
          "name": "enable_cache",
          "type": "boolean",
          "default": false,
          "description": "是否启用缓存",
          "label": "启用向量缓存",
          "ui_type": "switch",
          "required": false,
          "hidden": false,
          "disabled": false,
          "order": 6,
          "hint": "适合重复写入较多的场景，默认关闭以保持路径更直观。",
          "choices": null
        }
      }
    },
